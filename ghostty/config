# ============================================================================
# PRODUCTIVITY WINDOW MANAGEMENT CONFIGURATION
# ============================================================================

# Window Size - Optimized for coding (wider than default for better code readability)
window-height = 28
window-width = 130

# Asymmetrical padding with color extension for seamless look
window-padding-x = 5
window-padding-y = 0,5
window-padding-balance = true
window-padding-color = extend

# Modern glassmorphic appearance
background-opacity = 0.95
background-blur = 10
background-opacity-cells = true

# Font configuration - JetBrains Mono for code, Nerd Font provides icons
font-family = "JetBrains Mono"
font-family = "Symbols Nerd Font"
font-size = 12
font-feature = +liga
font-feature = +calt
font-shaping-break = cursor
grapheme-width-method = unicode

# Window behavior for productivity workflow
maximize = false
fullscreen = false

# Tab management (GTK) - Show tabs when needed, add new tabs after current
window-show-tab-bar = auto
window-new-tab-position = current

# Split management - Subtle dimming to highlight focused split
unfocused-split-opacity = 0.75
split-divider-color = "#8B4513"

# Enhanced mouse behavior
mouse-hide-while-typing = true
mouse-scroll-multiplier = 3.0
mouse-shift-capture = false

# Window decorations - Clean but functional
window-decoration = auto
theme = Nord
window-colorspace = "display-p3"

# Bright window title
window-titlebar-foreground = "#ffffff"
window-titlebar-background = "#0066cc"

# Working directory inheritance for efficient navigation
window-inherit-working-directory = true
# Keep consistent font size across windows
window-inherit-font-size = false

# Custom title format with directory tab
title = Terminal
window-subtitle = working-directory

# Enhanced cursor
cursor-style = block

# Performance optimizations
gtk-single-instance = detect
alpha-blending = linear-corrected
linux-cgroup-memory-limit = 2147483648
scrollback-limit = 10000

# Linux-specific optimizations
x11-instance-name = ghostty
class = com.mitchellh.ghostty

# Custom keybindings for coding workflow (non-defaults only)
keybind = ctrl+shift+e=new_split:right
keybind = ctrl+shift+d=new_split:down
keybind = ctrl+shift+h=goto_split:left
keybind = ctrl+shift+j=goto_split:bottom
keybind = ctrl+shift+l=goto_split:right
keybind = ctrl+shift+k=goto_split:top
keybind = ctrl+shift+z=toggle_split_zoom

# Shell integration for smart behavior
shell-integration = detect
shell-integration-features = cursor,sudo,title
