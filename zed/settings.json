// Zed settings

{
  "diff_view_style": "split",
  "cli_default_open_behavior": "new_window",
  "agent_buffer_font_size": 17.0,
  "language_models": {
    "opencode": {
      "show_go_models": false,
      "show_zen_models": false
    },
    "openai_compatible": {
      "Bifrost": {
        "api_url": "http://localhost:8080/v1",
        "available_models": [
          {
            "name": "gemini/gemma-4-31b-it",
            "max_tokens": 200000,
            "max_output_tokens": 32000,
            "max_completion_tokens": 200000,
            "capabilities": {
              "tools": true,
              "images": true,
              "parallel_tool_calls": false,
              "prompt_cache_key": false,
              "chat_completions": true,
              "interleaved_reasoning": false
            }
          },
          {
            "name": "gemini/gemma-4-26b-a4b-it",
            "max_tokens": 200000,
            "max_output_tokens": 32000,
            "max_completion_tokens": 200000,
            "capabilities": {
              "tools": true,
              "images": true,
              "parallel_tool_calls": false,
              "prompt_cache_key": false,
              "chat_completions": true,
              "interleaved_reasoning": false
            }
          },
          {
            "name": "mistral/mistral-small-2603",
            "max_tokens": 200000,
            "max_output_tokens": 32000,
            "max_completion_tokens": 200000,
            "capabilities": {
              "tools": true,
              "images": false,
              "parallel_tool_calls": false,
              "prompt_cache_key": false,
              "chat_completions": true,
              "interleaved_reasoning": false
            }
          },
          {
            "name": "mistral/mistral-medium-3-5",
            "max_tokens": 200000,
            "max_output_tokens": 32000,
            "max_completion_tokens": 200000,
            "capabilities": {
              "tools": true,
              "images": false,
              "parallel_tool_calls": false,
              "prompt_cache_key": false,
              "chat_completions": true,
              "interleaved_reasoning": false
            }
          },
          {
            "name": "mistral/mistral-large-2512",
            "max_tokens": 200000,
            "max_output_tokens": 32000,
            "max_completion_tokens": 200000,
            "capabilities": {
              "tools": true,
              "images": false,
              "parallel_tool_calls": false,
              "prompt_cache_key": false,
              "chat_completions": true,
              "interleaved_reasoning": false
            }
          },
          {
            "name": "mistral/devstral-2512",
            "max_tokens": 200000,
            "max_output_tokens": 32000,
            "max_completion_tokens": 200000,
            "capabilities": {
              "tools": true,
              "images": false,
              "parallel_tool_calls": false,
              "prompt_cache_key": false,
              "chat_completions": true,
              "interleaved_reasoning": false
            }
          },
          {
            "name": "mistral/ministral-14b-2512",
            "max_tokens": 200000,
            "max_output_tokens": 32000,
            "max_completion_tokens": 200000,
            "capabilities": {
              "tools": true,
              "images": false,
              "parallel_tool_calls": false,
              "prompt_cache_key": false,
              "chat_completions": true,
              "interleaved_reasoning": false
            }
          }
        ]
      }
    }
  },
  "project_panel": {
    "dock": "left"
  },
  "outline_panel": {
    "dock": "left"
  },
  "collaboration_panel": {
    "dock": "left"
  },
  "git_panel": {
    "dock": "left"
  },
  "agent": {
    "default_model": {
      "provider": "Bifrost",
      "model": "mistral/devstral-2512",
      "enable_thinking": false
    },
    "dock": "right"
  },
  "agent_ui_font_size": 17.0,

  "sticky_scroll": {
    "enabled": false
  },

  "context_servers": {
    "WebSearch": {
      "enabled": true,
      "remote": false,
      "command": "web-search-mcp",
      "args": [],
      "env": {}
    }
  },

  "theme": "One Dark",
  "ui_font_size": 18.0,
  "base_keymap": "VSCode",
  "buffer_font_size": 17,
  "wrap_guides": [100, 110],
  "icon_theme": {
    "light": "Zed (Default)",
    "dark": "Zed (Default)"
  },

  "tab_bar": {
    "show": true
  },
  "title_bar": {
    "button_layout": "standard",
    "show_menus": false,
    "show_user_menu": true,
    "show_branch_name": false,
    "show_user_picture": false
  },

  "colorize_brackets": true,
  "show_whitespaces": "none",
  "indent_guides": {
    "coloring": "indent_aware"
  },
  "ui_font_family": "Arial",
  "buffer_line_height": "standard",
  "telemetry": {
    "diagnostics": false,
    "metrics": false
  },
  "auto_install_extensions": {
    "ini": true,
    "xml": true,
    "log": true,
    "html": true,
    "toml": true,
    "django": true,
    "ansible": true,
    "codebook": true,
    "terraform": true,
    "ssh-config": true,
    "dockerfile": true,
    "git-firefly": true,
    "docker-compose": true
  },
  "terminal": {
    "button": false,
    "font_size": 16,
    "font_family": "MesloLGM Nerd Font Mono",
    "cursor_shape": "underline",
    "blinking": "on",
    "copy_on_select": true,
    "detect_venv": {
      "on": {
        "directories": [".venv", "venv", ".env", "env"],
        "activate_script": "default"
      }
    }
  },
  "tabs": {
    "show_close_button": "hover",
    "close_position": "right",
    "git_status": false
  },
  "gutter": {
    "folds": true,
    "min_line_number_digits": 0
  },
  "minimap": {
    "show": "never"
  },
  "cursor_shape": "underline",
  "cursor_blink": true,
  "autosave": "on_focus_change",
  "buffer_font_family": "JetBrainsMono Nerd Font",
  "file_types": {
    "jinja-html": [
      "**/templates/*.html",
      "**/views/*.html",
      "**/*.j2",
      "**/*.jinja"
    ],
    "Ansible": [
      "**.ansible.yml",
      "**.ansible.yaml",
      "**/defaults/*.yml",
      "**/defaults/*.yaml",
      "**/meta/*.yml",
      "**/meta/*.yaml",
      "**/tasks/*.yml",
      "**/tasks/*.yaml",
      "**/handlers/*.yml",
      "**/handlers/*.yaml",
      "**/group_vars/*.yml",
      "**/group_vars/*.yaml",
      "**/host_vars/*.yml",
      "**/host_vars/*.yaml",
      "**/playbooks/*.yml",
      "**/playbooks/*.yaml",
      "**playbook*.yml",
      "**playbook*.yaml"
    ]
  },
  "languages": {
    "Ansible": {
      "tab_size": 2,
      "format_on_save": "on",
      "formatter": "language_server"
    },
    "Python": {
      "tab_size": 4,
      "formatter": "auto",
      "format_on_save": "on",
      "language_servers": ["basedpyright", "ruff"]
    },
    "YAML": {
      "tab_size": 2,
      "format_on_save": "on",
      "formatter": "language_server"
    },
    "Markdown": {
      "tab_size": 2,
      "format_on_save": "on"
    }
  },
  "lsp": {
    "basedpyright": {
      "settings": {
        "basedpyright": {
          "typeCheckingMode": "standard",
          "analysis": {
            "diagnosticMode": "workspace",
            "inlayHints": {
              "callArgumentNames": false,
              "variableTypes": false,
              "functionReturnTypes": false
            },
            "autoImportCompletions": true
          }
        }
      }
    },
    "ruff": {
      "initialization_options": {
        "settings": {
          "lineLength": 100,
          "lint": {
            "extendSelect": [
              "E",
              "F",
              "I",
              "N",
              "W",
              "UP",
              "B",
              "C4",
              "SIM",
              "PTH"
            ]
          }
        }
      }
    },
    "yaml-language-server": {
      "settings": {
        "yaml": {
          "schemas": {
            "https://raw.githubusercontent.com/ansible/ansible-lint/main/src/ansiblelint/schemas/inventory.json": [
              "./inventory/*.yaml",
              "hosts.yml"
            ]
          }
        }
      }
    }
  }
}
